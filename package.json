{
  "name": "journal-search-mcp",
  "version": "1.0.0",
  "description": "MCP Server untuk pencarian & verifikasi jurnal akademik PDF (Tavily + Gemini Flash Lite worker swarm)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@modelcontextprotocol/sdk": "^1.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "pdf-parse": "^1.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/pdf-parse": "^1.1.4",
    "typescript": "^5.6.3"
  }
}
